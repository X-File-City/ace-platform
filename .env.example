# ACE Platform Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string (sync driver for Celery workers)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ace_platform

# PostgreSQL async connection string (for API/MCP server)
# If not set, automatically derived from DATABASE_URL
# DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5432/ace_platform

# =============================================================================
# REDIS
# =============================================================================
# Redis connection for Celery task queue
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# OPENAI
# =============================================================================
# OpenAI API key for LLM calls (required)
OPENAI_API_KEY=sk-...

# Embedding model for semantic playbook matching (used by find_playbook/list_playbooks task ranking)
# PLAYBOOK_EMBEDDING_MODEL=text-embedding-3-small

# Maximum characters included when generating playbook match embeddings
# PLAYBOOK_EMBEDDING_MAX_CHARS=12000

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Secret key for JWT token signing (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# JWT algorithm (default: HS256)
# JWT_ALGORITHM=HS256

# Access token expiration in minutes (default: 30)
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration in days (default: 7)
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# BILLING (Optional - disabled by default)
# =============================================================================
# Enable Stripe billing integration
BILLING_ENABLED=false

# Stripe secret key (required if BILLING_ENABLED=true)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret (required if BILLING_ENABLED=true)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Product IDs (create in Stripe Dashboard, then configure here)
# STRIPE_STARTER_PRODUCT_ID=prod_...
# STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
# STRIPE_STARTER_YEARLY_PRICE_ID=price_...

# STRIPE_PRO_PRODUCT_ID=prod_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...

# STRIPE_ENTERPRISE_PRODUCT_ID=prod_...

# =============================================================================
# OAUTH AUTHENTICATION (Optional)
# =============================================================================
# Enable social login with Google and/or GitHub

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: http://localhost:8000/auth/oauth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth
# Create OAuth App at: https://github.com/settings/developers
# 1. Set Homepage URL: http://localhost:3000
# 2. Set Authorization callback URL: http://localhost:8000/auth/oauth/github/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Base URL for OAuth redirect callbacks (your API server URL)
# OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# Frontend URL for post-OAuth redirects
# FRONTEND_URL=http://localhost:3000

# Session secret for OAuth state cookies (separate from JWT for security isolation)
# If not set, falls back to JWT_SECRET_KEY - but a separate key is recommended for production
# SESSION_SECRET_KEY=another-long-random-string-different-from-jwt

# =============================================================================
# MCP SERVER
# =============================================================================
# MCP server bind host
# MCP_SERVER_HOST=0.0.0.0

# MCP server port
# MCP_SERVER_PORT=8001

# =============================================================================
# EVOLUTION THRESHOLDS
# =============================================================================
# Number of unprocessed outcomes to trigger automatic evolution
# EVOLUTION_OUTCOME_THRESHOLD=5

# =============================================================================
# API SERVER
# =============================================================================
# API server bind host
# API_HOST=0.0.0.0

# API server port
# API_PORT=8000

# Allowed CORS origins (comma-separated in env, or JSON array)
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Trusted proxy CIDRs for forwarded client-IP parsing.
# Keep loopback defaults for local dev; add upstream proxy ranges in prod if needed.
# TRUSTED_PROXY_CIDRS=["127.0.0.1/32", "::1/128"]

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Environment name: development, staging, production
ENVIRONMENT=development

# Enable debug mode (verbose logging, SQL echo)
DEBUG=false

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# Resend API key for sending transactional emails (leave empty to disable)
# Get your API key at: https://resend.com/api-keys
# RESEND_API_KEY=re_...

# From address for outgoing emails (must be verified in Resend)
# EMAIL_FROM_ADDRESS=noreply@aceagent.io

# From name for outgoing emails
# EMAIL_FROM_NAME=ACE Platform

# Email verification token expiration in hours (default: 24)
# EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
# Sentry DSN for error tracking (leave empty to disable)
# Get this from your Sentry project settings
# SENTRY_DSN=https://...@sentry.io/...

# Performance monitoring sample rate (0.0 to 1.0, default: 0.1)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Profiling sample rate (0.0 to 1.0, default: 0.1)
# SENTRY_PROFILES_SAMPLE_RATE=0.1
